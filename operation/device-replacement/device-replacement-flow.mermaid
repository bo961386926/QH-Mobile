flowchart TD
    Start([运维中心 · 点击「设备操作」]) --> SelectPage[设备选择页]

    subgraph DeviceSelect [第一步：选择设备]
        direction TB
        AutoGPS[自动GPS定位] --> RadiusFilter[范围过滤]
        RadiusFilter --> QuickAction{快速识别?}
        QuickAction -->|扫一扫/NFC/手动| SelectDevice[选中设备]
        SelectDevice --> NextPage([进入模式选择])
    end

    SelectPage --> DeviceSelect

    subgraph ModePage [第二步：操作模式选择]
        direction LR
        Pick{选择模式}
        Pick -->|🔧 设备更换| EnterReplace([进入更换表单])
        Pick -->|📦 拆除后安装| EnterInstall([进入安装表单])
        Pick -->|🗑️ 设备拆除| EnterRemove([进入拆除表单])
    end

    NextPage --> ModePage

    %% ===== 进入表单 → 先打卡 =====
    EnterReplace --> ClockRemind
    EnterInstall --> ClockRemind
    EnterRemove --> ClockRemind

    ClockRemind["📍 进入表单<br/>⚠️ 提醒：请先完成作业打卡"] --> StartClock["🎬 开始打卡<br/>计时器启动 · 持续运行"]

    %% 打卡 + 填表并行
    StartClock --> FillStart[开始填写步骤]

    %% ===== 更换模式 =====
    FillStart --> ReplaceOld[步骤1 · 旧设备拆除<br/>设备编号 · 拆除原因 · 去向]
    ReplaceOld --> ReplaceNew[步骤2 · 拆除后安装<br/>新设备编号扫码/NFC · 安装位置]
    ReplaceNew --> ReplaceEvidence[步骤3 · 现场证据<br/>水印照片+视频]
    ReplaceEvidence --> ReplaceData[步骤4 · 数据填报<br/>选指标 → 逐一手动填值]
    ReplaceData --> EndClock

    %% ===== 安装模式 =====
    FillStart --> InstallDevice[步骤1 · 新设备信息<br/>设备编号扫码/NFC · 安装位置]
    InstallDevice --> InstallEvidence[步骤2 · 现场证据<br/>水印照片+视频]
    InstallEvidence --> InstallData[步骤3 · 数据填报<br/>选指标 → 逐一手动填值]
    InstallData --> EndClock

    %% ===== 拆除模式 =====
    FillStart --> DemoDevice[步骤1 · 旧设备拆除<br/>设备编号 · 拆除原因 · 去向]
    DemoDevice --> DemoEvidence[步骤2 · 现场证据<br/>水印照片+视频]
    DemoEvidence --> EndClock

    %% ===== 结束打卡 =====
    EndClock["⏹️ 结束打卡<br/>jobEndTime 记录"]

    EndClock --> Validate{提交校验}
    Validate -->|未开始打卡| Err1["❌ 请先完成作业打卡"]
    Validate -->|未结束打卡| Err2["❌ 请先结束打卡"]
    Validate -->|字段缺失| Err3["❌ 补填缺失项"]
    Err1 --> StartClock
    Err2 --> EndClock
    Err3 --> FillStart

    Validate -->|通过| CloudSubmit

    subgraph CloudSubmit [☁️ 云上报]
        direction TB
        UploadAnim[上报中...] --> UploadDone[上报成功]
        UploadDone --> Summary["摘要展示 · 清除暂存"]
    end

    %% ===== 打卡旁路 =====
    StartClock -.->|⏱ 计时器持续运行| EndClock

    %% ===== 分两次到场说明 =====
    CloudSubmit --> SplitNote
    SplitNote["💡 分两次到场怎么处理？<br/>第一次：选「设备拆除」模式 → 拆旧返厂<br/>第二次：选「设备更换」模式 → 到现场装新<br/>两次各独立打卡，两张独立工单"]

    FillStart -.->|底部操作| GlobalActions
    subgraph GlobalActions [通用底部操作]
        direction LR
        SaveDraft[💾 暂存草稿]
        ResetForm[🔄 清空表单]
    end

    style Start fill:#007AFF,color:#fff,stroke:none
    style DeviceSelect fill:#F0F8FF,stroke:#007AFF
    style ModePage fill:#F0F0FF,stroke:#7B61FF
    style ClockRemind fill:#FFF3E0,stroke:#FF6D00
    style StartClock fill:#FF6D00,color:#fff,stroke:none
    style EndClock fill:#4CAF50,color:#fff,stroke:none
    style CloudSubmit fill:#F0F0FF,stroke:#007AFF
    style SplitNote fill:#FFF8E1,stroke:#FFC107
    style GlobalActions fill:#F5F5F5,stroke:#C7C7CC
    style Err1 fill:#FFEBEE,color:#C62828,stroke:#EF5350
    style Err2 fill:#FFEBEE,color:#C62828,stroke:#EF5350
    style Err3 fill:#FFEBEE,color:#C62828,stroke:#EF5350
